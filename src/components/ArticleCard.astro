---
interface Props {
  title: string;
  date: Date;
  perex: string;
  cover?: string;
  href: string;
  tag?: string;
}
const { title, date, perex, cover, href, tag } = Astro.props;
const dateStr = new Intl.DateTimeFormat('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' }).format(date);
---
<article class="card">
  <a href={href} class="card-media" aria-hidden="true" tabindex="-1">
    {cover ? <img src={cover} alt="" loading="lazy" /> : <div class="card-media--ph"></div>}
    {tag && <span class="card-tag">{tag}</span>}
  </a>
  <div class="card-body">
    <time class="card-date" datetime={date.toISOString()}>{dateStr}</time>
    <h3 class="card-title"><a href={href}>{title}</a></h3>
    <p class="card-perex">{perex}</p>
    <a href={href} class="card-more">Číst více →</a>
  </div>
</article>

<style>
  .card {
    display: flex; flex-direction: column;
    background: #fff; border: 1px solid var(--color-line);
    border-radius: var(--radius); overflow: hidden;
    transition: transform 0.15s ease, box-shadow 0.2s ease;
  }
  .card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
  .card-media { display: block; aspect-ratio: 16 / 10; position: relative; overflow: hidden; }
  .card-media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
  .card:hover .card-media img { transform: scale(1.05); }
  .card-media--ph { width: 100%; height: 100%; background: linear-gradient(135deg, var(--color-green-light), #d6e9e3); }
  .card-tag {
    position: absolute; top: 0.8rem; left: 0.8rem;
    background: var(--color-orange); color: #fff;
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.03em;
    padding: 0.3rem 0.7rem; border-radius: 999px; text-transform: uppercase;
  }
  .card-body { padding: 1.3rem 1.4rem 1.5rem; display: flex; flex-direction: column; flex: 1; }
  .card-date { font-size: 0.82rem; color: var(--color-muted); font-weight: 600; }
  .card-title { font-size: 1.2rem; margin: 0.4rem 0 0.6rem; line-height: 1.25; }
  .card-title a { color: var(--color-ink); text-decoration: none; }
  .card-title a:hover { color: var(--color-green); }
  .card-perex { font-size: 0.97rem; color: var(--color-muted); margin: 0 0 1rem; flex: 1; }
  .card-more { font-weight: 700; color: var(--color-green); text-decoration: none; }
  .card-more:hover { color: var(--color-orange); }
</style>
