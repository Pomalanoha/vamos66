---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const projektTitle: Record<string, string> = Object.fromEntries(
  (await getCollection('projekty')).map((p) => [p.slug, p.data.title])
);

const clanky = (await getCollection('clanky'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<BaseLayout title="Aktuality" description="Aktuality z našich akcí a činnosti spolku VAMOS 66.">
  <PageHero
    eyebrow="Co je nového"
    title="Aktuality"
    subtitle="Reportáže, pozvánky a novinky ze všech našich projektů na jednom místě."
  />

  <section class="section">
    <div class="container">
      <div class="grid grid--3">
        {clanky.map((c) => (
          <ArticleCard
            title={c.data.title}
            date={c.data.date}
            perex={c.data.perex}
            cover={c.data.cover}
            tag={projektTitle[c.data.category] ?? 'Aktuality'}
            href={`/clanky/${c.slug}/`}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
