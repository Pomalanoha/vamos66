---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Icon from '../components/Icon.astro';
import { site } from '../config/site';

const projekty = (await getCollection('projekty'))
  .filter((p) => p.data.showOnHome)
  .sort((a, b) => a.data.order - b.data.order);

const clanky = (await getCollection('clanky'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const projektTitle: Record<string, string> = Object.fromEntries(
  (await getCollection('projekty')).map((p) => [p.slug, p.data.title])
);
---
<BaseLayout>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <span class="hero-badge">Spolek na podporu sportovních legend</span>
        <h1>Společně<br />zvládneme vše</h1>
        <p class="hero-lead">
          Pomáháme bývalým legendám z oblasti sportu, kultury i veřejného života –
          přímo i nepřímo, pokud se ocitli v obtížné sociální či zdravotní situaci.
        </p>
        <div class="hero-actions">
          <a href={site.donate} class="btn btn--primary" target="_blank" rel="noopener">Podpořit nás</a>
          <a href="/projekty/" class="btn btn--ghost">Naše projekty</a>
        </div>
      </div>
      <div class="hero-visual">
        <img src="/Legendy.png" alt="Legendy sportu — členové a hosté spolku VAMOS 66" />
        <div class="hero-chip"><strong>VAMOS</strong> = „pojďme, makej, do toho!"</div>
      </div>
    </div>
  </section>

  <!-- MISE / hodnoty -->
  <section class="section">
    <div class="container">
      <div class="section-head text-center mx-auto">
        <span class="eyebrow">Naše poslání</span>
        <h2>Vážíme si těch, kteří nás inspirovali</h2>
        <p class="lead mx-auto">
          Mnoho legend máme stále v paměti, jiné pomalu upadají v zapomnění.
          Připomínáme jejich příběhy a pomáháme tam, kde je to potřeba.
        </p>
      </div>
      <div class="grid grid--3">
        <div class="value">
          <span class="value-icon"><Icon name="medal" /></span>
          <h3>Úcta k legendám</h3>
          <p>Oslavujeme osobnosti, které ovlivnily český sport i kulturu, a pomáháme jim v těžkých chvílích.</p>
        </div>
        <div class="value">
          <span class="value-icon"><Icon name="heart" /></span>
          <h3>Konkrétní pomoc</h3>
          <p>Jednorázově přispíváme na zdravotní a rehabilitační pomůcky i léčebné terapie.</p>
        </div>
        <div class="value">
          <span class="value-icon"><Icon name="rocket" /></span>
          <h3>Naděje pro talenty</h3>
          <p>Zviditelňujeme mladé nadějné sportovce dříve, než se stanou hvězdami.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROJEKTY -->
  <section class="section section--soft">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Co děláme</span>
        <h2>Naše projekty</h2>
        <p class="lead">Sport, kultura i sociální oblast. Sedm cest, kterými přinášíme radost a pomoc.</p>
      </div>
      <div class="grid grid--3">
        {projekty.map((p) => (
          <ProjectCard
            title={p.data.title}
            perex={p.data.perex}
            cover={p.data.cover}
            icon={p.data.icon}
            href={`/projekty/${p.slug}/`}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- DARUJ pruh -->
  <section class="section section--green">
    <div class="container donate">
      <div>
        <span class="eyebrow">Darujme.cz</span>
        <h2>Děkujeme, že s námi pomáháte</h2>
        <p class="lead">
          Jen díky Vám můžeme přinášet radost našim sportovním legendám
          a pomáhat těm, kteří to potřebují. Bez Vás by to nešlo.
        </p>
      </div>
      <a href={site.donate} class="btn btn--light" target="_blank" rel="noopener">Přispět na Darujme.cz</a>
    </div>
  </section>

  <!-- AKTUALITY -->
  <section class="section">
    <div class="container">
      <div class="section-head between">
        <div>
          <span class="eyebrow">Co je nového</span>
          <h2>Aktuality</h2>
        </div>
        <a href="/aktuality/" class="btn btn--ghost">Všechny aktuality</a>
      </div>
      <div class="grid grid--3">
        {clanky.map((c) => (
          <ArticleCard
            title={c.data.title}
            date={c.data.date}
            perex={c.data.perex}
            cover={c.data.cover}
            tag={projektTitle[c.data.category] ?? 'Aktuality'}
            href={`/clanky/${c.slug}/`}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { background: linear-gradient(160deg, #0c2722 0%, #0e7c66 100%); color: #fff; overflow: hidden; }
  .hero-grid { display: grid; gap: clamp(2rem, 5vw, 4rem); align-items: center; padding-block: clamp(3rem, 7vw, 5.5rem); }
  @media (min-width: 880px) { .hero-grid { grid-template-columns: 1.05fr 0.95fr; } }
  .hero-badge {
    display: inline-block; background: rgba(255,255,255,0.14);
    color: #ffd9b0; font-weight: 700; font-size: 0.82rem; letter-spacing: 0.06em;
    padding: 0.45rem 1rem; border-radius: 999px; margin-bottom: 1.4rem; text-transform: uppercase;
  }
  .hero-text h1 { color: #fff; font-size: clamp(2.4rem, 6vw, 4rem); line-height: 1.04; }
  .hero-lead { color: rgba(255,255,255,0.92); font-size: clamp(1.1rem, 2vw, 1.35rem); max-width: 46ch; margin-bottom: 2rem; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 1rem; }
  .hero-actions .btn--ghost { color: #fff; border-color: rgba(255,255,255,0.4); }
  .hero-actions .btn--ghost:hover { background: rgba(255,255,255,0.1); color: #fff; border-color: #fff; }
  .hero-visual { position: relative; }
  .hero-visual img { border-radius: var(--radius); box-shadow: var(--shadow-lg); width: 100%; aspect-ratio: 4/3; object-fit: contain; background: #0c1a33; }
  .hero-chip {
    position: absolute; bottom: -18px; left: -10px;
    background: #fff; color: var(--color-ink); font-size: 0.92rem;
    padding: 0.7rem 1.1rem; border-radius: 12px; box-shadow: var(--shadow);
  }
  .hero-chip strong { color: var(--color-orange); }

  .value { text-align: center; padding: 0 0.5rem; }
  .value-icon {
    display: inline-grid; place-items: center; width: 64px; height: 64px;
    background: var(--color-green-light); color: var(--color-green);
    border-radius: 18px; margin-bottom: 1rem;
  }
  .value h3 { margin-bottom: 0.4rem; }
  .value p { color: var(--color-muted); }

  .section-head.between { display: flex; align-items: flex-end; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; }

  .donate { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .donate > div { max-width: 60ch; }
  .donate .btn { flex-shrink: 0; }
</style>
