---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const featured = (await getCollection('partneri'))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  featured.map(async (p) => ({ data: p.data, Content: (await p.render()).Content }))
);

const dalsi = [
  { name: 'Obec Kyšice', url: 'https://www.kysice.eu/', logo: 'https://842c9edb4e.clvaw-cdnwnd.com/a11f719e7b2bf16fa20a4126a384bd79/200000760-e5672e5674/crest.png?ph=842c9edb4e' },
  { name: 'MČ Praha 21', url: 'https://praha21.cz/', logo: 'https://842c9edb4e.clvaw-cdnwnd.com/a11f719e7b2bf16fa20a4126a384bd79/200000763-d6331d633e/1544368265576_p21-znak-cerna-h50n.png?ph=842c9edb4e' },
  { name: 'Stravování Hrbek', url: 'https://stravovanihrbek.websnadno.cz/', logo: 'https://842c9edb4e.clvaw-cdnwnd.com/a11f719e7b2bf16fa20a4126a384bd79/200000832-1e24b1e24d/kucha%C5%99%20logo%20%C4%8Derven%C3%BD.jpeg?ph=842c9edb4e' },
  { name: 'Aquarius IS', url: 'http://www.aquarius-is.cz/', logo: 'https://842c9edb4e.clvaw-cdnwnd.com/a11f719e7b2bf16fa20a4126a384bd79/200000767-5e2af5e2b1/sta%C5%BEen%C3%BD%20soubor.jpeg?ph=842c9edb4e' },
  { name: 'FyzioFit', url: 'https://fyziofit.eu/', logo: 'https://842c9edb4e.clvaw-cdnwnd.com/a11f719e7b2bf16fa20a4126a384bd79/200000754-1646a1646d/Fyziofit.png?ph=842c9edb4e' },
  { name: 'Veselé stopy', url: 'https://veselestopy.cz/', logo: 'https://842c9edb4e.clvaw-cdnwnd.com/a11f719e7b2bf16fa20a4126a384bd79/200000769-939d6939d8/301571725_405009025072178_3242040232220397337_n.png?ph=842c9edb4e' },
  { name: 'Förch', url: 'https://www.foerch.cz/', logo: 'https://842c9edb4e.clvaw-cdnwnd.com/a11f719e7b2bf16fa20a4126a384bd79/200000842-c4553c4554/FOERCH_Wort-Bildmarke_RGB%20%281%29.png?ph=842c9edb4e' },
];
---
<BaseLayout title="Partneři" description="Spolupracující firmy a partneři spolku, spřátelené firmy a podporovatelé.">
  <PageHero
    eyebrow="Děkujeme"
    title="VAMOS 66 spolupracuje"
    subtitle="Za podporu děkujeme všem partnerům, kteří nám pomáhají naplňovat naše poslání."
  />

  <section class="section">
    <div class="container">
      <div class="partners">
        {rendered.map(({ data, Content }) => (
          <article class="partner">
            {data.logo && (
              <div class="partner-logo">
                <img src={data.logo} alt={data.name} loading="lazy" />
              </div>
            )}
            <h3>
              {data.url
                ? <a href={data.url} target="_blank" rel="noopener">{data.name}</a>
                : data.name}
            </h3>
            <div class="partner-text"><Content /></div>
            {data.url && <a class="partner-link" href={data.url} target="_blank" rel="noopener">Navštívit web →</a>}
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <div class="section-head text-center mx-auto">
        <span class="eyebrow">A další</span>
        <h2>Spřátelené firmy a podporovatelé</h2>
      </div>
      <ul class="chips">
        {dalsi.map((d) => (
          <li>
            <a href={d.url} target="_blank" rel="noopener" title={d.name} aria-label={d.name}>
              <img src={d.logo} alt={d.name} loading="lazy" />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .partners { display: grid; gap: clamp(1.4rem, 3vw, 2rem); }
  @media (min-width: 720px) { .partners { grid-template-columns: repeat(2, 1fr); } }
  .partner {
    background: #fff; border: 1px solid var(--color-line); border-radius: var(--radius);
    padding: 1.6rem 1.7rem; border-left: 5px solid var(--color-orange);
  }
  .partner-logo {
    display: flex; align-items: center; height: 56px; margin-bottom: 1rem;
  }
  .partner-logo img { max-height: 56px; max-width: 160px; width: auto; height: auto; object-fit: contain; }
  .partner h3 { margin-bottom: 0.6rem; }
  .partner h3 a { color: var(--color-ink); text-decoration: none; }
  .partner h3 a:hover { color: var(--color-green); }
  .partner-text { color: var(--color-muted); font-size: 0.97rem; }
  .partner-text :global(p) { margin: 0 0 0.8rem; }
  .partner-link { font-weight: 700; }
  .chips { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 1.2rem; justify-content: center; align-items: center; }
  .chips a {
    display: flex; align-items: center; justify-content: center;
    height: 72px; width: 150px; background: #fff; border: 1px solid var(--color-line);
    border-radius: var(--radius); padding: 0.9rem 1.2rem; transition: all 0.15s ease;
  }
  .chips a:hover { border-color: var(--color-green); transform: translateY(-2px); box-shadow: var(--shadow); }
  .chips img { max-height: 100%; max-width: 100%; object-fit: contain; }
</style>
