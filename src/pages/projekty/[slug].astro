---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import ImageWrap from '../../components/ImageWrap.astro';

export async function getStaticPaths() {
  const projekty = await getCollection('projekty');
  return projekty.map((p) => ({ params: { slug: p.slug }, props: { entry: p } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const clanky = (await getCollection('clanky'))
  .filter((c) => c.data.category === entry.slug)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<BaseLayout title={entry.data.title} description={entry.data.perex}>
  <PageHero
    eyebrow="Projekt"
    title={entry.data.title}
    subtitle={entry.data.perex}
    image={entry.data.cover}
  />

  <section class="section">
    <div class="container two-col">
      <div class="prose">
        <Content components={{ ImageWrap }} />
      </div>
      <aside class="side">
        <div class="side-card side-card--green">
          <h3>Podpořte tento projekt</h3>
          <p>Vaše pomoc má smysl. Děkujeme za každý příspěvek.</p>
          <a href="https://www.darujme.cz/projekt/1210364" class="btn btn--light" target="_blank" rel="noopener">Přispět</a>
        </div>
        <div class="side-card">
          <h3>Další projekty</h3>
          <ul class="side-links">
            <li><a href="/projekty/">Přehled všech projektů →</a></li>
            <li><a href="/aktuality/">Aktuality →</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </section>

  {clanky.length > 0 && (
    <section class="section section--soft">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">Z tohoto projektu</span>
          <h2>Články a reportáže</h2>
        </div>
        <div class="grid grid--3">
          {clanky.map((c) => (
            <ArticleCard
              title={c.data.title}
              date={c.data.date}
              perex={c.data.perex}
              cover={c.data.cover}
              href={`/clanky/${c.slug}/`}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .two-col { display: grid; gap: clamp(2rem, 5vw, 3.5rem); }
  @media (min-width: 900px) { .two-col { grid-template-columns: 1.7fr 1fr; align-items: start; } }
  .side { display: grid; gap: 1.4rem; position: sticky; top: 96px; }
  .side-card { background: var(--color-bg-soft); border: 1px solid var(--color-line); border-radius: var(--radius); padding: 1.6rem; }
  .side-card h3 { margin-bottom: 0.8rem; }
  .side-card--green { background: var(--color-green); color: #fff; }
  .side-card--green h3 { color: #fff; }
  .side-card--green p { color: rgba(255,255,255,0.9); }
  .side-links { list-style: none; margin: 0; padding: 0; }
  .side-links li { margin-bottom: 0.6rem; }
  .side-links a { font-weight: 600; }
</style>
